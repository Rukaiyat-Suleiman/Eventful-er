    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "log4js": "^6.9.1",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
