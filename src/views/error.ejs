<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - Eventful-er</title>
    <style>
        body {
            margin: 0;
            font-family: 'Outfit', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f7f9fc;
            color: #2b2d42;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .error-card {
            background-color: #ffffff;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            padding: 40px;
            border-radius: 16px;
            text-align: center;
            max-width: 500px;
            width: 100%;
            margin: 20px;
        }

        .error-icon {
            font-size: 64px;
            margin-bottom: 20px;
        }

        h1 {
            color: #e63946;
            margin: 0 0 10px 0;
            font-size: 28px;
        }

        p {
            color: #4a5568;
            font-size: 16px;
            line-height: 1.6;
            margin: 0 0 30px 0;
        }

        .home-btn {
            background-color: #1d3557;
            color: white;
            text-decoration: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            transition: background-color 0.2s ease;
            display: inline-block;
        }

        .home-btn:hover {
            background-color: #457b9d;
        }
    </style>
</head>

<body>
    <div class="error-card">
        <div class="error-icon">
            <svg style="width: 64px; height: 64px; margin: 0 auto; display: block; color: #e63946;" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
        </div>
        <h1>Something went wrong</h1>
        <p><%= message %></p>
        <a href="/" class="home-btn">Go to Home</a>
    </div>
</body>

</html>
